model FileUploadeds {
  id String @id @default(cuid())
  name String
  url String
  article Articles? @relation("ArticleFile")
  articleId String?
  project Projects? @relation("ProjectFile")
  projectId String?
  user Users? @relation("UserBanner")
  userId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Projects {
  id String @id @default(cuid())
  title String
  link String
  description String
  technologies Skills[]
  autor Users @relation("UserProjects", fields: [autorId], references: [id])
  autorId String
  views String[] @default([])
  banner FileUploadeds @relation("ProjectFile", fields: [bannerId], references: [id])
  bannerId String @unique
  createdAt DateTime @default(now())
}


model Skills {
  id String @id @default(cuid())
  name String
  icon String
  projects    Projects[]
  createdAt DateTime @default(now())
}

model Articles {
  id String @id @default(cuid())
  title String
  content String
  description String
  autor Users @relation("UserArticles", fields: [autorId], references: [id])
  autorId String
  views String[] @default([])
  banner FileUploadeds @relation("ArticleFile", fields: [bannerId], references: [id])
  bannerId String @unique
  createdAt DateTime @default(now())
}

model Users {
  id String @id @default(cuid())
  fullname String
  email String @unique
  address String
  phone String
  description String
  jobRole String
  jobDescription String
  freelance Boolean
  isAvailable Boolean
  password String
  role String
  age Int
  articles Articles[] @relation("UserArticles")
  projects Projects[] @relation("UserProjects")
  banner FileUploadeds? @relation("UserBanner", fields: [bannerId], references: [id])
  bannerId String? @unique
  createdAt DateTime @default(now())
}




